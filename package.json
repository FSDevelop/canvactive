{
  "name": "canvactive",
  "version": "0.8.0",
  "description": "Small reactive state bindings for canvas rendering.",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./elements": {
      "types": "./dist/core/elements/index.d.ts",
      "import": "./dist/core/elements/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "vite --config examples/counter/vite.config.ts examples/counter",
    "dev:counter": "vite --config examples/counter/vite.config.ts examples/counter",
    "dev:focus": "vite --config examples/focus-board/vite.config.ts examples/focus-board",
    "dev:game": "vite --config examples/game-loop/vite.config.ts examples/game-loop",
    "dev:input": "vite --config examples/input-runner/vite.config.ts examples/input-runner",
    "dev:spawner": "vite --config examples/entity-spawner/vite.config.ts examples/entity-spawner",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "canvas",
    "reactivity",
    "observer",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^8.0.11"
  }
}
