{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Canvactive",
  "scopeName": "source.canvactive",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#script-block"
    },
    {
      "include": "#render-block"
    },
    {
      "include": "#create-block"
    },
    {
      "include": "#update-block"
    },
    {
      "include": "#tags"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.html.canvactive",
          "begin": "<!--",
          "end": "-->"
        }
      ]
    },
    "script-block": {
      "name": "meta.embedded.block.javascript.canvactive",
      "begin": "(<)(script)(?:(\\s+)(scene))?(\\s*>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.canvactive"
        },
        "2": {
          "name": "entity.name.tag.script.canvactive"
        },
        "3": {
          "name": "punctuation.whitespace.attribute.canvactive"
        },
        "4": {
          "name": "entity.other.attribute-name.scene.canvactive"
        },
        "5": {
          "name": "punctuation.definition.tag.end.canvactive"
        }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.canvactive"
        },
        "2": {
          "name": "entity.name.tag.script.canvactive"
        },
        "3": {
          "name": "punctuation.definition.tag.end.canvactive"
        }
      },
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "render-block": {
      "name": "meta.embedded.block.javascript.canvactive",
      "begin": "(<)(render)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.canvactive"
        },
        "2": {
          "name": "entity.name.tag.render.canvactive"
        },
        "3": {
          "name": "punctuation.definition.tag.end.canvactive"
        }
      },
      "end": "(</)(render)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.canvactive"
        },
        "2": {
          "name": "entity.name.tag.render.canvactive"
        },
        "3": {
          "name": "punctuation.definition.tag.end.canvactive"
        }
      },
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "create-block": {
      "name": "meta.embedded.block.javascript.canvactive",
      "begin": "(<)(create)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.canvactive"
        },
        "2": {
          "name": "entity.name.tag.create.canvactive"
        },
        "3": {
          "name": "punctuation.definition.tag.end.canvactive"
        }
      },
      "end": "(</)(create)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.canvactive"
        },
        "2": {
          "name": "entity.name.tag.create.canvactive"
        },
        "3": {
          "name": "punctuation.definition.tag.end.canvactive"
        }
      },
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "update-block": {
      "name": "meta.embedded.block.javascript.canvactive",
      "begin": "(<)(update)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.canvactive"
        },
        "2": {
          "name": "entity.name.tag.update.canvactive"
        },
        "3": {
          "name": "punctuation.definition.tag.end.canvactive"
        }
      },
      "end": "(</)(update)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.canvactive"
        },
        "2": {
          "name": "entity.name.tag.update.canvactive"
        },
        "3": {
          "name": "punctuation.definition.tag.end.canvactive"
        }
      },
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "tags": {
      "patterns": [
        {
          "name": "meta.tag.canvactive",
          "begin": "(</?)([A-Za-z][A-Za-z0-9-]*)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.tag.begin.canvactive"
            },
            "2": {
              "name": "entity.name.tag.canvactive"
            }
          },
          "end": "(/?>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.tag.end.canvactive"
            }
          }
        }
      ]
    }
  }
}
